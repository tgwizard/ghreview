{
  "name": "@tgwizard/ghreview",
  "version": "0.0.7",
  "description": "A local web UI for reviewing large GitHub PRs, backed by the gh CLI.",
  "type": "module",
  "bin": {
    "ghreview": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node scripts/build.mjs",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/sanitize-html": "2.16.1",
    "esbuild": "0.28.0",
    "highlight.js": "11.11.1",
    "marked": "18.0.2",
    "open": "10.2.0",
    "parse-diff": "0.11.1",
    "sanitize-html": "2.17.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tgwizard/ghreview.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
