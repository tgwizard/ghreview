{
  "name": "ghreview",
  "version": "0.0.1",
  "description": "A local web UI for reviewing large GitHub PRs, backed by the gh CLI.",
  "type": "module",
  "bin": {
    "ghreview": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "open": "^10.1.0",
    "parse-diff": "^0.11.1",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tgwizard/ghreview.git"
  },
  "license": "MIT"
}
